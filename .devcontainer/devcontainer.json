{
  "name": "apex-localops",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/powershell:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/azure/azure-dev/azd:latest": {}
  },
  "containerEnv": {
    "AZURE_DEFAULTS_LOCATION": "swedencentral",
    "GH_TOKEN": "${localEnv:GH_TOKEN}"
  },
  "remoteEnv": {
    "GH_TOKEN": "${localEnv:GH_TOKEN}"
  },
  "onCreateCommand": "sudo apt-get update && sudo apt-get install -y --no-install-recommends ca-certificates curl jq unzip zip less bash-completion dos2unix && sudo rm -rf /var/lib/apt/lists/*",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "mounts": [
    "source=apex-localops-azure,target=/home/vscode/.azure,type=volume",
    "source=apex-localops-powershell,target=/home/vscode/.local/share/powershell,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-bicep",
        "ms-vscode.azurecli",
        "ms-vscode.powershell",
        "ms-azuretools.azure-dev",
        "GitHub.vscode-pull-request-github",
        "github.vscode-github-actions"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n"
      }
    }
  },
  "remoteUser": "vscode"
}
